  "input": {
    "task_id": "fixture-mock-llm-provider-disabled",
    "provider": {
      "name": "external-chat-provider",
      "enabled": false
    },
    "mock_llm": {
      "enabled": true,
      "model": "mock-local-llm",
      "responses": [
        {
          "content": "Proposal accepted for local validation.",
          "usage": {
            "input_tokens": 11,
            "output_tokens": 6
          },
          "tool_calls": [
            {
              "name": "record_validation"
            }
          ]
        },
        {
          "content": "Validation passed with provider disabled.",
          "usage": {
            "input_tokens": 9,
            "output_tokens": 7
          }
        }
      ]
    },
    "workflow": {
      "steps": [
        {
          "id": "interpret",
          "expect_contains": "accepted"
        },
        {
          "id": "validate",
          "expect_contains": "provider disabled"
        }
      ]
    }
