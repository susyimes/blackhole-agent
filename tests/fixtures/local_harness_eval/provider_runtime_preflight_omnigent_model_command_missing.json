{
  "name": "provider-runtime-preflight-omnigent-model-command-missing",
  "behavior": "provider_runtime_preflight",
  "input": {
    "task_id": "fixture-provider-runtime-preflight-omnigent-model-command-missing",
    "provider": {
      "name": "omnigent-yaml-agent",
      "harness": "omnigent",
      "model_command_required": true
    },
    "sandbox": {
      "active": false,
      "type": "none"
    },
    "runtime": {
      "platform": "linux",
      "cli_resolved_in_runner": true,
      "launch_transport": "subprocess"
    },
    "runner_env": {
      "parent_env_keys": [
        "PATH"
      ],
      "allowlist": [
        "PATH"
      ],
      "passthrough": []
    }
  },
  "assertions": [
    {
      "path": "route_status",
      "equals": "blocked"
    },
    {
      "path": "failure_mode",
      "equals": "provider_model_command_missing"
    },
    {
      "path": "model_command.required",
      "equals": true
    },
    {
      "path": "model_command.configured",
      "equals": false
    },
    {
      "path": "model_command.ok",
      "equals": false
    },
    {
      "path": "model_command.raw_command_exported",
      "equals": false
    },
    {
      "path": "runtime.runner_invoked",
      "equals": false
    },
    {
      "path": "preflight.blocked_before_launch",
      "equals": true
    }
  ]
}
