{
  "name": "mock-llm-multimodal-text-encoded-blocks",
  "behavior": "mock_llm_workflow_route",
  "input": {
    "task_id": "fixture-mock-llm-multimodal-text-encoded-blocks",
    "provider": {
      "name": "gateway-provider",
      "enabled": false,
      "model": "vision-model",
      "model_input": [
        "text",
        "image"
      ]
    },
    "mock_llm": {
      "enabled": true,
      "responses": [
        {
          "content": "should not execute"
        }
      ]
    },
    "workflow": {
      "steps": [
        {
          "id": "describe-image",
          "prompt": "[{\"type\":\"input_text\",\"text\":\"Describe this image.\"},{\"type\":\"input_image\",\"image_url\":\"data:image/png;base64,ZmFrZQ==\"}]",
          "expect_contains": "should not execute"
        }
      ]
    }
  },
  "assertions": [
    {
      "path": "route_status",
      "equals": "failed"
    },
    {
      "path": "failure_mode",
      "equals": "text_encoded_multimodal_blocks"
    },
    {
      "path": "mock_llm.call_count",
      "equals": 0
    },
    {
      "path": "workflow.steps_executed",
      "equals": 0
    },
    {
      "path": "multimodal_preflight.ok",
      "equals": false
    },
    {
      "path": "multimodal_preflight.text_encoded_multimodal_block_count",
      "equals": 1
    },
    {
      "path": "multimodal_preflight.model_image_input_declared",
      "equals": true
    },
    {
      "path": "multimodal_preflight.prompt_bodies_exported",
      "equals": false
    }
  ]
}
