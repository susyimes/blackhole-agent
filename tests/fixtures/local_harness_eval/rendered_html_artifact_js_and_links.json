{
  "name": "rendered-html-artifact-js-and-links",
  "behavior": "rendered_html_artifact_validation",
  "input": {
    "task_id": "fixture-rendered-html-artifact-js-and-links",
    "artifact": {
      "kind": "html",
      "rendered_boundary": "rendered_html_artifact",
      "html_body": "PRIVATE_RENDERED_HTML_BODY_DO_NOT_EXPORT"
    },
    "browser": {
      "available": true,
      "sandbox_allows_scripts": true
    },
    "script_probe": {
      "expected_execution": true,
      "observed_execution": true
    },
    "link_probes": [
      {
        "label": "plain-external-anchor",
        "href": "https://example.com/private-link-do-not-export",
        "declared_target": "",
        "expected_navigation": "new_frame",
        "observed_navigation": "new_frame"
      },
      {
        "label": "target-blank-external-anchor",
        "href": "https://example.com/private-blank-link-do-not-export",
        "declared_target": "_blank",
        "expected_navigation": "new_frame",
        "observed_navigation": "new_frame"
      }
    ],
    "snapshot_gate": {
      "required": true,
      "state": "empty_landing",
      "baseline_hash": "sha256:fixture-empty-landing-baseline",
      "current_hash": "sha256:fixture-empty-landing-current",
      "diff_hash": "sha256:fixture-empty-landing-diff",
      "diff_status": "clean",
      "empty_state_expected": true,
      "empty_state_observed": true,
      "baseline_path": "PRIVATE_BASELINE_SNAPSHOT_PATH_DO_NOT_EXPORT",
      "current_path": "PRIVATE_CURRENT_SNAPSHOT_PATH_DO_NOT_EXPORT"
    }
  },
  "assertions": [
    {
      "path": "route_status",
      "equals": "passed"
    },
    {
      "path": "artifact.rendered_boundary",
      "equals": "rendered_html_artifact"
    },
    {
      "path": "artifact.html_body_exported",
      "equals": false
    },
    {
      "path": "browser.sandbox_allows_scripts",
      "equals": true
    },
    {
      "path": "script_execution.passed",
      "equals": true
    },
    {
      "path": "link_navigation.probe_count",
      "equals": 2
    },
    {
      "path": "link_navigation.same_frame_anchor_count",
      "equals": 1
    },
    {
      "path": "link_navigation.target_blank_anchor_count",
      "equals": 1
    },
    {
      "path": "link_navigation.all_expected_new_frame",
      "equals": true
    },
    {
      "path": "link_navigation.passed",
      "equals": true
    },
    {
      "path": "snapshot_gate.required",
      "equals": true
    },
    {
      "path": "snapshot_gate.state",
      "equals": "empty_landing"
    },
    {
      "path": "snapshot_gate.baseline_hash_present",
      "equals": true
    },
    {
      "path": "snapshot_gate.current_hash_present",
      "equals": true
    },
    {
      "path": "snapshot_gate.empty_state_observed",
      "equals": true
    },
    {
      "path": "snapshot_gate.passed",
      "equals": true
    },
    {
      "path": "privacy.html_body_exported",
      "equals": false
    },
    {
      "path": "privacy.raw_urls_exported",
      "equals": false
    },
    {
      "path": "privacy.snapshot_paths_exported",
      "equals": false
    },
    {
      "path": "failure_mode",
      "equals": "none"
    }
  ]
}
