{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SVM-23 Hourly GitHub Growth Digest",
  "type": "object",
  "additionalProperties": false,
  "required": ["digest_id", "generated_at", "repositories", "items", "proposals"],
  "properties": {
    "digest_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "repositories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cursor": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "query", "sort", "order", "repositories"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["github_trending_repositories"]
        },
        "query": { "type": "string" },
        "sort": { "type": "string" },
        "order": { "type": "string" },
        "window_days": { "type": "integer", "minimum": 1 },
        "min_stars": { "type": "integer", "minimum": 0 },
        "total_count": { "type": "integer", "minimum": 0 },
        "incomplete_results": { "type": "boolean" },
        "event_fetch_errors": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repo", "error"],
            "properties": {
              "repo": { "type": "string" },
              "error": { "type": "string" }
            }
          }
        },
        "repositories": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "full_name",
              "html_url",
              "stargazers_count",
              "forks_count",
              "star_delta_since_last_run",
              "first_seen",
              "created_at",
              "updated_at",
              "pushed_at"
            ],
            "properties": {
              "full_name": { "type": "string" },
              "html_url": { "type": "string" },
              "description": { "type": "string" },
              "language": { "type": ["string", "null"] },
              "stargazers_count": { "type": "integer", "minimum": 0 },
              "forks_count": { "type": "integer", "minimum": 0 },
              "open_issues_count": { "type": "integer", "minimum": 0 },
              "star_delta_since_last_run": { "type": ["integer", "null"] },
              "first_seen": { "type": "boolean" },
              "created_at": { "type": "string" },
              "updated_at": { "type": "string" },
              "pushed_at": { "type": "string" },
              "topics": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_url", "event_kind", "summary", "relevance_reason", "confidence"],
        "properties": {
          "item_id": { "type": "string" },
          "source_url": { "type": "string" },
          "event_kind": { "type": "string" },
          "summary": { "type": "string" },
          "relevance_reason": { "type": "string" },
          "risk_flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["proposal_id", "kind", "summary", "requires_approval"],
        "properties": {
          "proposal_id": { "type": "string" },
          "proposal_source": {
            "type": "string",
            "enum": ["heuristic", "llm_interpretation"]
          },
          "kind": {
            "type": "string",
            "enum": ["documentation", "test", "code_patch", "config", "follow_up_issue", "no_action"]
          },
          "summary": { "type": "string" },
          "evidence_urls": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk_flags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "implementation_scope": {
            "type": "string",
            "enum": ["local_validation_candidate", "risk_review_before_local_change", "reviewable_proposal_only"]
          },
          "validation_gate": { "type": "string" },
          "validation_task": { "type": "string" },
          "rationale": { "type": "string" },
          "uncertainty": { "type": "string" },
          "self_effect": { "type": "string" },
          "action_lane": { "type": "string" },
          "requires_approval": { "type": "boolean" }
        }
      }
    }
  }
}

